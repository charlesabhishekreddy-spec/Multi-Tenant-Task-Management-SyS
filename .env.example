# App
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Auth
JWT_ACCESS_SECRET=replace_with_long_secret
JWT_REFRESH_SECRET=replace_with_another_long_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/task_manager?schema=public

# OAuth (Google)
GOOGLE_CLIENT_ID=your_google_client_id
AUTO_PROVISION_OAUTH_USERS=true

# Optional CORS comma-separated origins
CORS_ORIGINS=
